# BTC Up/Down history data config
# Script: npm run btc-updown

# Rolling window: only markets closed in the last N days (from now).
# Omit for no period filter.
BTC_UPDOWN_DAYS_BACK=14

# Timeframes to fetch. Comma-separated: 5m, 15m, 1h. Omit for all.
# BTC_UPDOWN_TIMEFRAMES=5m,15m,1h

# JSON file path to save results. Omit to skip JSON output.
# BTC_UPDOWN_OUTPUT=btc-updown.json

# Set to true to include title column in console output.
# BTC_UPDOWN_VERBOSE=false
